---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import Remark42 from '../../components/Remark42.astro';

export async function getStaticPaths() {
	const posts = await getCollection('articles');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
	title={post.data.title}
	description={post.data.description}
	navCurrent="writing"
>
	<article class="prose">
		<p class="post-meta">
			<time datetime={post.data.pubDate.toISOString()}>
				{
					post.data.pubDate.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})
				}
			</time>
			{
				post.data.updatedDate && (
					<>
						{' '}
						· Updated{' '}
						<time datetime={post.data.updatedDate.toISOString()}>
							{post.data.updatedDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</time>
					</>
				)
			}
		</p>
		<h1>{post.data.title}</h1>
		<Content />
		{
			post.data.linkedinUrl && (
				<p>
					<a href={post.data.linkedinUrl} rel="noopener noreferrer">
						Originally on LinkedIn
					</a>
				</p>
			)
		}
	</article>

	<Remark42 identifier={`writing:${post.id}`} title={post.data.title} />
</BaseLayout>
