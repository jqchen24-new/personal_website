---
interface Props {
	identifier: string;
	title: string;
}

const { identifier, title } = Astro.props;
const shortname = import.meta.env.PUBLIC_DISQUS_SHORTNAME;

if (!shortname) {
	// No shortname set; render nothing.
	return null;
}

const pageUrl = Astro.url.href;
---

<section aria-label="Comments">
	<div id="disqus_thread"></div>
</section>

<script is:inline>
	const disqusShortname = {JSON.stringify(shortname)};
	const disqusPageUrl = {JSON.stringify(pageUrl)};
	const disqusIdentifier = {JSON.stringify(identifier)};
	const disqusTitle = {JSON.stringify(title)};

	var disqus_config = function () {
		this.page.url = disqusPageUrl;
		this.page.identifier = disqusIdentifier;
		this.page.title = disqusTitle;
	};

	(function () {
		if (document.getElementById('disqus-embed-script')) return;
		var d = document;
		var s = d.createElement('script');
		s.id = 'disqus-embed-script';
		s.src = 'https://' + disqusShortname + '.disqus.com/embed.js';
		s.setAttribute('data-timestamp', String(+new Date()));
		(d.head || d.body).appendChild(s);
	})();
</script>

<noscript>
	Please enable JavaScript to view the comments powered by Disqus.
</noscript>
